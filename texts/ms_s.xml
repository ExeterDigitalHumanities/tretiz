               <l n="125">En le <choice><orig>vn</orig><reg>un</reg></choice> gimel sunt les <term xml:id="S-gouns-001" key="AND:gon_1">gouns</term><choice><orig/><reg>,</reg></choice> <gloss place="interlinear" xml:lang="enm" key="MED:20967" target="#S-gouns-001">hokes</gloss></l>
               <l n="126">Et <term xml:id="S-vertivels-001" key="AND:vertevele"><choice><orig>vertiuels</orig><reg>vertivels</reg></choice></term> sunt mis a gouns<choice><orig/><reg>.</reg></choice> <gloss place="interlinear" xml:lang="enm" key="MED:47532" target="#S-vertivels-001">twistes</gloss></l>
               <l n="127">E p<ex>ar</ex> <term xml:id="S-cliket-001" key="AND:cliket">cliket</term> <choice><orig>&amp;</orig><reg>e</reg></choice> p<ex>ar</ex> <term xml:id="S-serure-001" key="AND:serrure">serure</term> <gloss place="interlinear" xml:lang="enm" key="MED:24519" target="#S-cliket-001">lache</gloss> <gloss place="interlinear" xml:lang="enm" key="25939" target="#S-serure-001">lok</gloss></l>
               <l n="128">Ert la meson plus ensure<choice><orig/><reg>.</reg></choice></l>
