            <cb n="1ra"/>
            <lg n="1">
               <l n="1">Plus est delit <choice><orig>enle</orig><reg>en le</reg></choice> oriole</l>
               <l n="2">Escuter la noise del <term xml:id="S-oriole-001" key="AND:oriol_1">oriole</term><choice><orig/><reg>.</reg></choice> <gloss place="interlinear" xml:lang="enm" key="MED:53284" target="#S-oriole-001">wodewale</gloss></l>
               <l n="3">Jeo vei ici <choice><orig>vn</orig><reg>un</reg></choice> <term xml:id="S-tesoun-001" key="AND:tessun">tesoun</term> <gloss place="interlinear" xml:lang="enm" key="MED:6126" target="#S-tesoun-001">brock</gloss></l>
               <l n="4"><choice><orig>Kad</orig><reg>K'ad</reg></choice> deguerpi sa meisoun</l>
               <l n="5">Pur la sente <choice><orig>dun</orig><reg>d'un</reg></choice> gopil</l>
               <l n="6">Ke <choice><orig>lad</orig><reg>l'ad</reg></choice> mis en exil<choice><orig/><reg>.</reg></choice></l>
               <l n="7">Jeo vai ci <choice><orig>vne</orig><reg>une</reg></choice> <term xml:id="S-putois-001" key="AND:putois">putois</term><choice><orig/><reg>.</reg></choice> <note type="editorial" resp="#TGH">The gloss is unclear. One would expect a nominal form (probably <foreign xml:lang="enm" key="MED:17933">fulmard</foreign>, based on the other MSS), but <foreign xml:lang="enm">illegued</foreign> looks verbal, possibly the past tense form of <foreign xml:lang="enm" key="MED:25017">leggen</foreign> (<quote>to speak against</quote>). In other <title>Tretiz</title> MSS, the equivalent line reads <quote><foreign xml:lang="fro">E maudit soit li mau putois</foreign></quote>; is it possible that <foreign xml:lang="enm">illegued</foreign> corresponded in an exemplar to <foreign xml:lang="fro">maudit</foreign> (with a sense along the lines of <mentioned>accused, criticised</mentioned>) but was erroneously copied across and ascribed to <foreign xml:lang="fro">putois</foreign> within the line as reworked here?</note> <gloss place="interlinear" xml:lang="enm" key="25017" target="#S-putois-001">illegued</gloss></l>
               <l n="8">Seit en vile<choice><orig/><reg>,</reg></choice> seit en bois<choice><orig/><reg>,</reg></choice></l>
               <l n="9">Jeo vodra meutz <choice><orig>vne</orig><reg>une</reg></choice> <term xml:id="S-belette-001" key="AND:belete">belette</term> <gloss place="interlinear" xml:lang="enm" key="MED:52340" target="#S-belette-001">wesle</gloss></l>
               <l n="10">De fere ma g<ex>ra</ex>nge de <choice><orig>Rats</orig><reg>rats</reg></choice> nette</l>
               <l n="11">Ke tous les taupes qe sount <choice><orig>trouez</orig><reg>trovez</reg></choice></l>
               <l n="12">En tere fouans p<ex>ar</ex>mi le pree<choice><orig/><reg>,</reg></choice></l>
               <l n="13"><choice><orig>Ela</orig><reg>E la</reg></choice> char de <choice><orig>Cerf</orig><reg>cerf</reg></choice> <choice><orig>&amp;</orig><reg>e</reg></choice> de foun</l>
               <l n="14">Ke la melodie de <choice><orig>Asne</orig><reg>asne</reg></choice> <choice><orig>&amp;</orig><reg>e</reg></choice> de poun<choice><orig/><reg>.</reg></choice></l>
               <l n="15">Plus cher ad dame cowe de poun</l>
               <l n="16">Ke de escheker fers ou poun<choice><orig/><reg>.</reg></choice></l>
               <l n="17">Jeo vei ci soutz la dume</l>
               <l n="18"><choice><orig>Vn</orig><reg>Un</reg></choice> oisel <choice><orig>plume</orig><reg>plumé</reg></choice><choice><orig/><reg>,</reg></choice> ci gist la plume<choice><orig/><reg>;</reg></choice></l>
               <l n="19">Mes cil qe les oiseaux ad <choice><orig>deplume</orig><reg>deplumé</reg></choice></l>
               <l n="20">Meutz vodra <choice><orig>qeil</orig><reg>qe il</reg></choice> eut nois blucee<choice><orig/><reg>.</reg></choice></l>
               <l n="21">Jeo vei ester <choice><orig>vn</orig><reg>un</reg></choice> petit <term xml:id="S-neym-001" key="AND:neim">neym</term> <gloss place="interlinear" xml:lang="enm" key="MED:12891" target="#S-neym-001">duarw</gloss></l>
               <l n="22">En la <choice><orig>Riuere</orig><reg>rivere</reg></choice> <choice><orig>qest</orig><reg>q'est</reg></choice> dit <mentioned><choice><orig>neyn</orig><reg>Neyn</reg></choice></mentioned><choice><orig/><reg>.</reg></choice></l>
               <l n="23"><choice><orig>Ensa</orig><reg>En sa</reg></choice> main tient <choice><orig>vn</orig><reg>un</reg></choice> <term xml:id="S-neyn-001" key="AND:ain_1">neyn</term><choice><orig/><reg>.</reg></choice> <gloss place="interlinear" xml:lang="enm" key="MED:20967" target="#S-neyn-001">hok</gloss></l>
               <l n="24">Pescher veout<choice><orig/><reg>,</reg></choice> ne peot p<ex>ur</ex> <term xml:id="S-ceym-001" key="AND:cem">ceym</term><choice><orig/><reg>.</reg></choice> <gloss place="interlinear" xml:lang="enm" key="MED:40841" target="#S-ceym-001">slet</gloss></l>
            </lg>
               <milestone unit="theme" type="partsOfACart"/>
            <lg n="2" part="I">
               <l n="25"><choice><orig><hi rend="large">I</hi>Eo</orig><reg>Jeo</reg></choice> <del type="subpunction">eo</del> vei venir <choice><orig>vne</orig><reg>une</reg></choice> charette<choice><orig/><reg>.</reg></choice></l>
               <l n="26"><choice><orig>bon</orig><reg>Bon</reg></choice> est qe moi entremette</l>
               <l n="27">En f<ex>ra</ex>nceis la charette decrire<choice><orig/><reg>.</reg></choice></l>
               <l n="28">E pur enfauntz mettr<ex>e</ex> en <choice><orig>liu</orig><reg>liv</reg></choice><ex>er</ex>e<choice><orig/><reg>,</reg></choice></l>
               <l n="29">En p<ex>ri</ex>mes voil nomer les <choice><orig>Reos</orig><reg>reos</reg></choice><choice><orig/><reg>,</reg></choice></l>
               <l n="30">Puis les bendes entour les <choice><orig>Reos</orig><reg>reos</reg></choice><choice><orig/><reg>.</reg></choice></l>
               <l n="31">Desoutz les bendes qe sunt de fer</l>
               <l n="32">Sunt les <term xml:id="S-jaunts-001" key="AND:jante_2">jaunts</term> estachetz de fer<choice><orig/><reg>.</reg></choice> <gloss place="interlinear" xml:lang="enm" key="MED:15563" target="#S-jaunts-001">velien</gloss></l>
               <l n="33">En les jaunts entre les <term xml:id="S-rais-001" key="AND:rai_1"><choice><orig>Rais</orig><reg>rais</reg></choice></term><choice><orig/><reg>,</reg></choice> <gloss place="interlinear" xml:lang="enm" key="MED:42312" target="#S-rais-001">spoken</gloss></l>
               <l n="34"><choice><sic>Dul</sic><corr>Del</corr></choice> solail issent les <choice><orig>Rais</orig><reg>rais</reg></choice><choice><orig/><reg>,</reg></choice></l>
            </lg>
               <cb n="1rb"/>
            <lg n="2" part="M">      
               <l n="35">De la mer viegnent les <term xml:id="S-raies-001" key="AND:rai_3"><choice><orig>Raies</orig><reg>raies</reg></choice></term><choice><orig/><reg>,</reg></choice> <gloss place="interlinear" xml:lang="enm" key="MED:16083" target="#S-raies-001">fisch</gloss></l>
               <l n="36">E ver la feire vount les <term xml:id="S-raies-002" key="AND:rai_2"><choice><orig>Raies</orig><reg>raies</reg></choice></term><choice><orig/><reg>.</reg></choice><note type="editorial" resp="#TGH">This form is attested as an erroneous variant plural of <foreign xml:lang="enm" key="MED:6315">burel</foreign> in the MED.</note> <gloss place="interlinear" xml:lang="enm" key="MED:6315" target="#S-raies-002">burelelez</gloss></l>
               <l n="37">Mes les <choice><orig>Raies</orig><reg>raies</reg></choice> de la charette</l>
               <l n="38">En les moaux <choice><orig>vnt</orig><reg>unt</reg></choice> recette<choice><orig/><reg>.</reg></choice></l>
               <l n="39">Seet le moal <choice><orig>enle</orig><reg>en le</reg></choice> <choice><orig>Reo</orig><reg>reo</reg></choice></l>
               <l n="40">E le moel en <choice><orig>vn</orig><reg>un</reg></choice> eof<choice><orig/><reg>;</reg></choice></l>
               <l n="41">Le <choice><orig>vn</orig><reg>un</reg></choice> est bon p<ex>ur</ex> fees porter<choice><orig/><reg>,</reg></choice></l>
               <l n="42">Le aultre est bon a manger<choice><orig/><reg>.</reg></choice></l>
               <l n="43">En le moal est mys le essil</l>
               <l n="44">E p<ex>ar</ex> deux heces se tent <choice><orig>keuil</orig><reg>kevil</reg></choice><choice><orig/><reg>.</reg></choice></l>
               <l n="45">Les eissils <choice><orig>vnt</orig><reg>unt</reg></choice> lour <term xml:id="S-juners-001" key="AND:junere">juners</term> <gloss place="interlinear" xml:lang="enm" key="MED:8158" target="#S-juners-001">cloutes</gloss></l>
               <l n="46">Ke lour eident cum bones freres<choice><orig/><reg>.</reg></choice></l>
               <l n="47">Sur <choice><orig>lessil</orig><reg>l'essil</reg></choice> git le <term xml:id="S-cartil-001" key="AND:chartil"><choice><orig>Cartil</orig><reg>cartil</reg></choice></term><choice><orig/><reg>,</reg></choice> <gloss place="interlinear" xml:lang="enm" key="MED:6867" target="#S-cartil-001">cartbodi</gloss></l>
               <l n="48">E p<ex>ur</ex> <choice><orig>sauuer</orig><reg>sauver</reg></choice> lui de p<ex>er</ex>il</l>
               <l n="49">Le <choice><orig>Cartil</orig><reg>cartil</reg></choice> est des <term xml:id="S-brahés-001" key="AND:brael"><choice><orig>brahes</orig><reg>brahés</reg></choice></term> <gloss place="interlinear" xml:lang="enm" key="MED:51833" target="#S-brahés-001">withen</gloss></l>
               <l n="50">Ferm <choice><orig>lyes</orig><reg>lyés</reg></choice> <choice><orig>ales</orig><reg>a les</reg></choice> essils<choice><orig/><reg>.</reg></choice></l>
               <l n="51">Entre le <choice><orig>Chartil</orig><reg>chartil</reg></choice> <choice><orig>eles</orig><reg>e les</reg></choice> moaux</l>
               <l n="52">Sunt <term xml:id="S-hordieres-001" key="AND:hurtour">hordieres</term> <choice><orig>trouez</orig><reg>trovez</reg></choice> deux<choice><orig/><reg>.</reg></choice> <gloss place="interlinear" xml:lang="enm" key="MED:6867" target="#S-hordieres-001">cartpinnes</gloss></l>
               <l n="53"><choice><orig>Iescun</orig><reg>Jescun</reg></choice> <choice><orig>Charette</orig><reg>charette</reg></choice> qe meine bleez</l>
               <l n="54">Deit <choice><orig>auer</orig><reg>aver</reg></choice> <choice><orig>Riddles</orig><reg>riddles</reg></choice> <choice><orig>acoutez</orig><reg>a coutez</reg></choice><choice><orig/><reg>.</reg></choice></l>
               <l n="55">En les <term xml:id="S-ridles-001" key="AND:ridele_1"><choice><orig>Ridles</orig><reg>ridles</reg></choice></term> sunt les <term xml:id="S-rolowes-001" key="AND:rouloun">rolowes</term><choice><orig/><reg>,</reg></choice> <gloss place="interlinear" xml:lang="enm" key="38121" target="#S-ridles-001">ronges</gloss> <gloss place="interlinear" xml:lang="enm" key="MED:38121" target="#S-rolowes-001"><choice><orig>rongstaues</orig><reg>rongstaves</reg></choice></gloss></l>
               <l n="56">P<ex>ar</ex> les <choice><orig>Reofs</orig><reg>reofs</reg></choice> s<add place="above">a</add>untz nule clowes<choice><orig/><reg>.</reg></choice></l>
               <l n="57">Outre les moaux sunt sauheres<choice><orig/><reg>.</reg></choice></l>
               <l n="58">Si <choice><orig>vnt</orig><reg>unt</reg></choice> les charettes <choice><sic>boure</sic><reg>lours</reg></choice> escheles<choice><orig/><reg>.</reg></choice></l>
               <l n="59">En les <term xml:id="S-lymons-001" key="AND:limon_1">lymons</term> va le <term xml:id="S-limoner-001" key="AND:limoner">limoner</term> <gloss place="interlinear" xml:lang="enm" key="MED:45290" target="#S-lymons-001">thille</gloss> <gloss place="interlinear" xml:lang="enm" key="MED:45290" target="#S-limoner-001">thilhors</gloss></l>
               <l n="60">Ki porte a doos <choice><orig>vn</orig><reg>un</reg></choice> <term xml:id="S-doser-001" key="AND:dosser">doser</term><choice><orig/><reg>,</reg></choice> <gloss place="interlinear" xml:lang="enm" key="MED:37502" target="#S-doser-001">rugwitthe</gloss></l>
               <l n="61">E au ventre <choice><orig>vn</orig><reg>un</reg></choice> <term xml:id="S-ventrer-001" key="AND:ventrer">ventrer</term><choice><orig/><reg>,</reg></choice> <gloss place="interlinear" xml:lang="enm" key="MED:53355" target="#S-ventrer-001">wombrop</gloss></l>
               <l n="62">E <choice><orig>ala</orig><reg>a la</reg></choice> <choice><orig>Cowe</orig><reg>cowe</reg></choice> <choice><orig>vn</orig><reg>un</reg></choice> <term xml:id="S-waluer-001" key="AND:valuer_1">waluer</term><choice><orig/><reg>.</reg></choice> <note type="lexical" resp="#TGH">Two forms of this word are recorded in MSS of the Tretiz and related texts: <foreign xml:lang="fro" key="avaluer">avaluer</foreign> (sometimes shortened to <foreign xml:lang="fro" key="valuer_1">valuer</foreign>) and <foreign xml:lang="fro" key="vauner">vauner</foreign>. AND has an attestation for each of these. Modern French preserves <foreign xml:lang="fra">avaloir</foreign> (see TLF: <quote><foreign xml:lang="fra">pièce du harnais qui descend derrière les cuisses des chevaux et les entoure à leur partie inférieure</foreign></quote>), attested already in the 13th century (Godefroy Compl. 8:245). This suggests that <foreign xml:lang="fro">(a)valuer</foreign> is the more etymologically sound of the two alternatives ('aval'= underneath + '-oir' suffix, a rope passing underneath/round the back of the horse), with <foreign xml:lang="fro">vauner</foreign> possibly derived from misreading of the 'u' as an 'n' and palatalisation of the 'l'.</note> <gloss place="interlinear" xml:lang="enm" key="MED:44407" target="#S-waluer-001">tailrop</gloss></l>
               <l n="63">Les trees si <choice><orig>vnt</orig><reg>unt</reg></choice> <term xml:id="S-braceroles-001" key="AND:bracerole_2">braceroles</term> <gloss place="interlinear" xml:lang="enm" key="MED:29863" target="#S-braceroles-001">nostles</gloss></l>
               <l n="64">Ke abracent les limons <choice><orig>&amp;</orig><reg>e</reg></choice> acolent<choice><orig/><reg>.</reg></choice></l>
               <l n="65"><choice><orig>Deuaunt</orig><reg>Devaunt</reg></choice> les braceroles sunt <term xml:id="S-billés-001" key="AND:billette_1"><choice><orig>billes</orig><reg>billés</reg></choice></term> <gloss place="interlinear" xml:lang="enm" key="MED:33400" target="#S-billés-001">pinnes</gloss></l>
               <l n="66">Ki de cuteux sunt round <term xml:id="S-dolés-001" key="AND:doler_1"><choice><orig>doles</orig><reg>dolés</reg></choice></term><choice><orig/><reg>.</reg></choice> <gloss place="interlinear" xml:lang="enm" key="MED:45754" target="#S-dolés-001">switen</gloss></l>
               <l n="67">Les cols des <choice><orig>chiuaux</orig><reg>chivaux</reg></choice> portent <term xml:id="S-esteles-001" key="AND:astele">esteles</term> <gloss place="interlinear" xml:lang="enm" key="MED:19895" target="#S-esteles-001">hamen</gloss></l>
               <l n="68">E colers de quir ou bourles ou celes<choice><orig/><reg>.</reg></choice></l>
