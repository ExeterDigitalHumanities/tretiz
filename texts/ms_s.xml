            </lg>
               <cb n="1vb"/>
            <lg n="4" part="F">
               <l n="103">Ceo est mur qe <choice><orig>enuiroun</orig><reg>enviroun</reg></choice> la <choice><orig>Court</orig><reg>court</reg></choice></l>
               <l n="104">Et mesere qe a coumble <choice><orig>a hurt</orig><reg>ahurt</reg></choice><choice><orig/><reg>.</reg></choice></l>
               <l n="105">Sus la mesere en <choice><orig>trauers</orig><reg>travers</reg></choice> outre</l>
               <l n="106">Amount le celer mettent le <term xml:id="S-poutre-001" key="AND:poutre">poutre</term><choice><orig/><reg>.</reg></choice> <gloss place="interlinear" xml:lang="enm" key="MED:53206" target="#S-poutre-001">wirtre</gloss></l>
               <l n="107">Et le piler desoutz le poutre</l>
               <l n="108">De <term xml:id="S-chevestres-001" key="AND:chevestre"><choice><orig>cheuestres</orig><reg>chevestres</reg></choice></term> lietz le poutre<choice><orig/><reg>.</reg></choice> <gloss place="interlinear" xml:lang="enm" key="MED:19873" target="#S-chevestres-001">haltre</gloss></l>
               <l n="109">En <choice><orig>uostre</orig><reg>vostre</reg></choice> soler<choice><orig/><reg>,</reg></choice> sus le poutre<choice><orig/><reg>,</reg></choice></l>
               <l n="110">Les <term xml:id="S-solins-001" key="AND:seilloun">solins</term> mettez outre<choice><orig/><reg>;</reg></choice> <note type="lexical" resp="#TGH">The equivalent Latin term is <foreign xml:lang="lat">soliva</foreign>, glossed as <foreign xml:lang="fro">sulle</foreign> and <foreign xml:lang="fro">solive</foreign> in MSS of John of Garland’s <title>Dictionarius</title> (see DMLBS, <foreign xml:lang="lat">soliva</foreign>: <quote>beam, rafter, sill</quote>. Some Tretiz witnesses (e.g. PT) give the word <foreign xml:lang="fro">solive</foreign> here; others (including GSY) have <foreign xml:lang="fro">seilloun</foreign>. The former word is doubtless derived from the Latin etymon; the latter appears to be the same term as the <title>Dictionarius</title> gloss <foreign xml:lang="fro">sulle</foreign> and is presumably to be related to English <foreign xml:lang="enm" key="MED:40342">sil(le)</foreign>. We have chosen to link to AND headwords <foreign xml:lang="fro" key="solive">solive</foreign> and <foreign xml:lang="fro" key="seilloun">seilloun</foreign> respectively, depending on each manuscript’s reading.</note> <gloss place="interlinear" xml:lang="enm" key="MED:18651" target="#S-solins-001">gistes</gloss></l>
               <l n="111">Amount les solins la <term xml:id="S-plauncié-001" key="AND:plancher_1"><choice><orig>plauncie</orig><reg>plauncié</reg></choice></term><choice><orig/><reg>,</reg></choice> <gloss place="interlinear" xml:lang="enm" key="MED:16387" target="#S-plauncié-001">floor</gloss></l>
               <l n="112">De bord ou plastre bien <choice><orig>pauie</orig><reg>pavié</reg></choice><choice><orig/><reg>.</reg></choice></l>
               <l n="113">Sus la mesere les trahez mettez<choice><orig/><reg>.</reg></choice></l>
               <l n="114">De deux <choice><orig>cheu</orig><reg>chev</reg></choice><ex>er</ex>ons le couple facez</l>
               <l n="115">Ke ferm esterra sus la mesere</l>
               <l n="116">P<ex>ar</ex> <choice><orig>kiuil</orig><reg>kivil</reg></choice> <choice><orig>&amp;</orig><reg>e</reg></choice> par <term xml:id="S-terere-001" key="AND:terere">terere</term><choice><orig/><reg>.</reg></choice> <gloss place="interlinear" xml:lang="enm" key="MED:52834" target="#S-terere-001">wimbel</gloss></l>
               <l n="117">De tute la meson <choice><orig>encoumble</orig><reg>en coumble</reg></choice> ap<ex>er</ex>t</l>
               <l n="118">En cele tect dunt est <choice><orig>couert</orig><reg>covert</reg></choice><choice><orig/><reg>.</reg></choice></l>
               <l n="119">En la chaumbre deit bien estre</l>
               <l n="120">Luminaire <choice><orig>ala</orig><reg>a la</reg></choice> fenestre<choice><orig/><reg>.</reg></choice></l>
               <l n="121">Al <choice><orig>entre</orig><reg>entré</reg></choice> del huis est la <term xml:id="S-lime-001" key="AND:lyme_2">lime</term> <gloss place="interlinear" xml:lang="enm" key="MED:45470" target="#S-lime-001">thresuold</gloss></l>
               <l n="122">Et outre la teste la <term xml:id="S-sullime-001" key="AND:suslime">sullime</term><choice><orig/><reg>.</reg></choice> <gloss place="interlinear" xml:lang="enm" key="MED:31961" target="#S-sullime-001"><choice><orig>ouerslai</orig><reg>overslai</reg></choice></gloss></l>
               <l n="123">De <choice><orig>couste</orig><reg>cousté</reg></choice> sunt les <term xml:id="S-gimmeux-001" key="AND:gemel">gimmeux</term> <gloss place="interlinear" xml:lang="enm" key="MED:12396 MED:46870" target="#S-gimmeux-001">doretren</gloss></l>
